local HttpService = game:GetService("HttpService")

local gameScripts = {
    [12345678] = "https://githubusercontent.com",
    [87654321] = "https://githubusercontent.com"
}

local universalScript = "https://githubusercontent.com"

local currentId = game.PlaceId
local targetUrl = gameScripts[currentId] or universalScript

local success, scriptCode = pcall(function()
    return HttpService:GetAsync(targetUrl)
end)

if success then
    loadstring(scriptCode)()
else
    warn("Failed to load script.")
end
